# Database
DATABASE_PATH=data/app.db

# Server
# PORT is read by the API server (Bun reads .env automatically)
PORT=3001
NODE_ENV=development
# Auth is bypassed by default in development.
# Set AUTH_DISABLED=false if you want to test real login/session flow.
AUTH_DISABLED=true
# Optional: specific email for auto-created dev user when DB has no users
# DEV_AUTH_EMAIL=dev@local.test

# Frontend URL (for CORS + magic link redirect)
WEB_URL=http://localhost:5173

# Email (Resend)
# Leave RESEND_API_KEY empty in dev — magic links will be printed to console.
# For quick testing with Resend free tier, use EMAIL_FROM=onboarding@resend.dev.
# For production, set EMAIL_FROM to your verified domain sender.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
